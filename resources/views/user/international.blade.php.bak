<div x-data="{ 
    withdrawMethod: '{{ request()->input("method") == "cryptocurrency" ? "Cryptocurrency" : "" }}',
    amount: '',
    accountName: '',
    accountNumber: '',
    bankName: '',
    bankAddress: '',
    accountType: 'Online Banking',
    country: '',
    swiftCode: '',
    iban: '',
    pin: '',
